# Supabase — obtén estos valores en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...          # anon/public key
SUPABASE_SERVICE_KEY=eyJhbGc...       # service_role key (solo para el API de save)

# Auth del admin — elige una contraseña segura
ADMIN_PASSWORD=tu-contrasena-segura

# Secreto para firmar los tokens JWT — genera uno aleatorio largo
JWT_SECRET=un-secreto-muy-largo-y-aleatorio-aqui
